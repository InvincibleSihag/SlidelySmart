# Database
DATABASE_URL=postgresql://slidely:slidely@localhost:5432/slidely

# Celery / Redis
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# GCP (optional — only needed for GCS result storage)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# GCS_BUCKET_NAME=slidely-presentations
# GCP_PROJECT_ID=your-project-id

# Pusher (optional — for real-time thought streaming)
# PUSHER_APP_ID=
# PUSHER_KEY=
# PUSHER_SECRET=
# PUSHER_CLUSTER=mt1

# Unsplash (image search for slides)
# UNSPLASH_ACCESS_KEY=

# Logging
LOG_LEVEL=INFO
LOG_JSON=false

NGROK_DOMAIN_DEFAULT=