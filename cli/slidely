#!/usr/bin/env bash
set -euo pipefail

# ──────────────────────────────────────────────────────────────
# Slidely CLI — thin docker compose wrapper
# ──────────────────────────────────────────────────────────────

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
DC="docker compose -f $REPO_ROOT/docker-compose.yml"
PID_DIR="$REPO_ROOT/.cli"
mkdir -p "$PID_DIR"

R='\033[1;31m' G='\033[1;32m' Y='\033[1;33m' B='\033[1;34m' C='\033[1;36m' NC='\033[0m'
log()  { printf "${G}[slidely]${NC} %b\n" "$*"; }
warn() { printf "${Y}[slidely]${NC} %b\n" "$*"; }
err()  { printf "${R}[slidely]${NC} %b\n" "$*" >&2; }

usage() {
  printf "${B}Slidely CLI${NC}\n\n"
  printf "${Y}Usage:${NC}  %s <command>\n\n" "$(basename "$0")"
  printf "${Y}Commands:${NC}\n"
  printf "  ${G}start${NC}       Start all services (backend + frontend)\n"
  printf "  ${G}stop${NC}        Stop all services\n"
  printf "  ${G}restart${NC}     Restart all services\n"
  printf "  ${G}share${NC}       Start all services + expose via ngrok\n"
  printf "  ${G}ngrok${NC}       Expose frontend via ngrok\n"
  printf "  ${G}logs${NC}        Tail docker compose logs\n"
  printf "  ${G}status${NC}      Show service statuses\n"
  printf "\n"
  exit 1
}

# ─── PID helpers (ngrok only) ───────────────────────────────

save_pid()  { echo "$2" > "$PID_DIR/$1.pid"; }
read_pid()  { cat "$PID_DIR/$1.pid" 2>/dev/null || echo ""; }
clear_pid() { rm -f "$PID_DIR/$1.pid"; }

is_running() {
  local pid; pid="$(read_pid "$1")"
  [[ -n "$pid" ]] && kill -0 "$pid" 2>/dev/null
}

kill_proc() {
  local pid; pid="$(read_pid "$1")"
  if [[ -n "$pid" ]] && kill -0 "$pid" 2>/dev/null; then
    kill "$pid" 2>/dev/null || true
    sleep 1
    kill -0 "$pid" 2>/dev/null && kill -9 "$pid" 2>/dev/null || true
  fi
  clear_pid "$1"
}

# ─── Commands ───────────────────────────────────────────────

cmd_start() {
  log "Starting all services..."
  $DC up -d --build
  log "Backend:  ${C}http://localhost:9753${NC}  Docs: ${C}http://localhost:9753/docs${NC}"
  log "Frontend: ${C}http://localhost:3000${NC}"
}

cmd_stop() {
  is_running "ngrok" && { log "Stopping ngrok..."; kill_proc "ngrok"; }
  pkill -x ngrok 2>/dev/null || true

  log "Stopping all services..."
  $DC down
  log "All stopped"
}

cmd_logs() {
  $DC logs -f
}

cmd_status() {
  $DC ps
  echo ""
  if is_running "ngrok"; then
    printf "${G}%-12s${NC} running (PID %s)\n" "ngrok" "$(read_pid ngrok)"
  else
    printf "${R}%-12s${NC} stopped\n" "ngrok"
  fi
}

# ─── ngrok ──────────────────────────────────────────────────

cmd_ngrok() {
  local domain
  domain="$(sed -n 's/^NGROK_DOMAIN=//p' "$REPO_ROOT/.local.env" 2>/dev/null | tr -d '"' || true)"
  domain="${domain#http://}"; domain="${domain#https://}"; domain="${domain%%/*}"
  [[ -z "$domain" ]] && { err "NGROK_DOMAIN not set in .local.env"; return 1; }

  pkill -x ngrok 2>/dev/null || true; clear_pid "ngrok"

  log "Starting ngrok -> https://$domain"
  ngrok http --url="$domain" 3000 > "$PID_DIR/ngrok.log" 2>&1 &
  save_pid "ngrok" $!
  sleep 2
  is_running "ngrok" && log "ngrok: ${C}https://$domain${NC}" || err "ngrok failed. Check $PID_DIR/ngrok.log"
}

# ─── Dispatch ───────────────────────────────────────────────

case "${1:-}" in
  start)     cmd_start ;;
  stop)      cmd_stop ;;
  restart)   cmd_stop; cmd_start ;;
  share)     cmd_start; cmd_ngrok ;;
  ngrok)     cmd_ngrok ;;
  logs)      cmd_logs ;;
  status)    cmd_status ;;
  *)         usage ;;
esac
