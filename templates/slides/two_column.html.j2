{% from "_macros.html.j2" import render_element, slide_bg, el_attrs, element_style %}
{#-
  Two-column layout. Element order convention:
  - First heading/title element → rendered as slide heading above columns
  - Remaining elements split into left/right columns:
    - Elements with metadata.column == "right" go right
    - All others go left
-#}
<div class="slide slide-two-column" data-slide-id="{{ slide.id }}"{{ slide_bg(slide) }}>
  {% for element in slide.elements %}
    {% if element.type in ("heading", "title") %}
      <h2 class="slide-heading" {{ el_attrs(element) }} {{ element_style(element) }}>{{ element.content | rich_text }}</h2>
      {% break %}
    {% endif %}
  {% endfor %}
  <div class="columns">
    <div class="column column-left">
      {% for element in slide.elements %}
        {% if element.type not in ("heading", "title") and not (element.metadata and element.metadata.column == "right") %}
          {{ render_element(element) }}
        {% endif %}
      {% endfor %}
    </div>
    <div class="column column-right">
      {% for element in slide.elements %}
        {% if element.type not in ("heading", "title") and element.metadata and element.metadata.column == "right" %}
          {{ render_element(element) }}
        {% endif %}
      {% endfor %}
    </div>
  </div>
</div>
